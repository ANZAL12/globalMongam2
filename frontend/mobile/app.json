{
  "expo": {
    "name": "Global Agencies",
    "slug": "global-agencies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/GLOBAL2.png",
    "scheme": [
      "global-agencies",
      "com.globalagencies.mobile",
      "com.googleusercontent.apps.862395033084-cpvd7pe1q7hlsujb796mcdp25pf17kvf",
      "com.googleusercontent.apps.862395033084-si99fukoqvv2mi35u7hsafvf5tpcmtkf"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globalagencies.mobile"
    },
    "android": {
      "package": "com.globalagencies.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/GLOBAL2_padded.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/GLOBAL1.png",
          "imageWidth": 100,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec0dc904-cf1d-4073-b1f3-14c658b50ec8"
      }
    }
  }
}